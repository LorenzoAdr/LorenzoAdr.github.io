---
import MainLayout from '../layouts/MainLayout.astro';

const title = 'Lorenzo Arias | Unified Engineering Dashboard';
const description =
	'Lifecycle engineering dashboard for real-time C++ systems: development, validation, and runtime operations.';
---

<MainLayout title={title} description={description} activeNav="intro">
	<section id="dashboard-home-view" class="hero-shell reveal intro-shell">
		<div class="intro-glow" aria-hidden="true"></div>
		<div class="hero-grid">
			<div class="hero-copy">
				<div class="hero-badge">
					<span class="hero-badge-dot" aria-hidden="true"></span>
					Unified engineering profile
				</div>
				<div class="hero-actions">
					<a href="https://github.com/LorenzoAdr" target="_blank" rel="noopener noreferrer" class="hero-github-chip">GitHub</a>
				</div>
				<h1 class="main-title">LORENZO ARIAS</h1>
				<p class="role">Real-Time Data and Systems Engineer</p>
				<p class="profile">
					Specialized in low-latency architecture for critical systems. My workflow integrates foundational infrastructure (C++/SHM),
					development and debugging tooling (TIE), and live integrity monitoring (Pulse Integrity). I pursue deterministic and efficient
					solutions for complex data challenges.
				</p>
			</div>
		</div>
	</section>

	<section id="dashboard-varmonitor-view" class="vm-embed-shell dashboard-hidden">
		<div class="vm-embed-frame-wrap">
			<iframe
				id="dashboard-varmonitor-iframe"
				class="vm-embed-frame"
				src="/VarMonitorPanel#shm"
				title="VarMonitor embedded view"
				loading="lazy"
			></iframe>
		</div>
	</section>
</MainLayout>

<style>
	.hero-shell {
		margin: 22px 20px;
		padding: 12px 0 0;
		position: relative;
		overflow: visible;
	}

	.intro-glow {
		pointer-events: none;
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.intro-glow::before {
		content: '';
		position: absolute;
		left: 50%;
		top: 0;
		width: 54rem;
		height: 28rem;
		transform: translateX(-50%);
		border-radius: 999px;
		background: rgb(6 182 212 / 0.1);
		filter: blur(120px);
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		align-items: center;
		gap: 28px;
		position: relative;
		z-index: 1;
	}

	.hero-copy {
		padding: 6px 0;
	}

	.hero-badge {
		margin: 0 0 14px;
		width: fit-content;
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 6px 14px;
		border-radius: 9999px;
		border: 1px solid rgb(34 211 238 / 0.2);
		background: rgb(6 182 212 / 0.05);
		font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgb(103 232 249 / 0.95);
	}

	.hero-actions {
		margin: 0 0 14px;
	}

	.hero-github-chip {
		display: inline-flex;
		align-items: center;
		padding: 6px 11px;
		border-radius: 10px;
		border: 1px solid rgb(148 163 184 / 0.2);
		background: rgb(255 255 255 / 0.05);
		color: #e2e8f0;
		text-decoration: none;
		font-size: 0.82rem;
		font-weight: 500;
		transition: border-color 0.25s ease, background-color 0.25s ease, color 0.25s ease;
	}

	.hero-github-chip:hover {
		border-color: rgb(34 211 238 / 0.35);
		background: rgb(6 182 212 / 0.1);
		color: #bae6fd;
	}

	.hero-badge-dot {
		width: 6px;
		height: 6px;
		border-radius: 999px;
		background: rgb(34 211 238);
		box-shadow: 0 0 10px rgb(34 211 238 / 0.75);
		animation: hero-dot-pulse 1.6s ease-in-out infinite;
	}

	.main-title {
		margin: 0;
		font-size: clamp(2.7rem, 6.6vw, 6.8rem);
		line-height: 1.02;
		letter-spacing: -0.03em;
		font-weight: 600;
		background: linear-gradient(to bottom, #ffffff, #64748b);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.role {
		margin: 12px 0 0;
		font-size: clamp(1.25rem, 2.6vw, 2rem);
		line-height: 1.2;
		letter-spacing: -0.01em;
		font-weight: 600;
		background: linear-gradient(to bottom, #ffffff, #64748b);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.profile {
		margin: 18px 0 0;
		max-width: 52ch;
		line-height: 1.72;
		color: #94a3b8;
		font-size: 1.115rem;
	}

	.reveal {
		opacity: 0;
		transform: translateY(16px);
		transition: opacity 700ms ease, transform 700ms ease;
	}

	.reveal.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	.dashboard-hidden {
		display: none !important;
	}

	.vm-embed-shell {
		margin: 18px 20px;
	}

	.vm-embed-frame-wrap {
		border: 1px solid rgb(51 65 85 / 0.55);
		border-radius: 16px;
		overflow: hidden;
		background: rgb(2 6 23 / 0.65);
	}

	.vm-embed-frame {
		display: block;
		width: 100%;
		height: calc(100vh - 48px);
		border: 0;
		background: rgb(2 6 23);
		color-scheme: dark;
	}

	@media (max-width: 720px) {
		.hero-shell {
			margin: 14px;
			padding-top: 8px;
		}

		.hero-grid {
			grid-template-columns: 1fr;
			gap: 18px;
		}

		.main-title {
			font-size: clamp(2.2rem, 11vw, 4.25rem);
		}

		.role {
			font-size: 1.04rem;
		}

		.profile {
			max-width: none;
		}

		.vm-embed-shell {
			margin: 14px;
		}

		.vm-embed-frame {
			height: calc(100vh - 40px);
		}
	}

	@keyframes hero-dot-pulse {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.35;
		}
	}
</style>

<script is:inline>
	(() => {
		const nodes = document.querySelectorAll('.reveal');
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					entry.target.classList.add('is-visible');
					observer.unobserve(entry.target);
				});
			},
			{ threshold: 0.12, rootMargin: '0px 0px -10% 0px' },
		);
		nodes.forEach((node) => observer.observe(node));

	})();
</script>
